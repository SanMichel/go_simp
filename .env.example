PORT=3000
APP_ENV=development
# REQUIRED: At least 32 characters
SESSION_SECRET=

# Local app state database. POSTGRES_URL is accepted for compatibility with tmp.
POSTGRES_URL=postgres://user:password@localhost:5432/simp_db?sslmode=disable

# SECURITY: The Oracle URL may appear in process listings and logs.
# Use a read-only database account with minimal privileges.
# Oracle source database used by product, company, and local lookups.
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=xe
ORACLE_USER=system
ORACLE_PASSWORD=password

# Optional direct Oracle URL. If set, it wins over ORACLE_HOST/PORT/SERVICE.
# ORACLE_URL=oracle://system:password@localhost:1521/xe
